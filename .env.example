# ============================================
# Sa-Token PHP - 测试环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================

# AES 加密测试密钥（SaTokenEncryptorTest）
TEST_AES_KEY=test-key-placeholder-32-bytes-lo

# SM4 加密测试密钥（SaTokenEncryptorTest）
TEST_SM4_KEY=test-key-placeholder-32-bytes-lo

# JWT 测试密钥（SaTokenJwtTest）
TEST_JWT_SECRET_KEY=test-key-placeholder-32-bytes-lo

# JWT SM 模式测试密钥（SaTokenJwtSmTest）
TEST_JWT_SM_SECRET_KEY=test-key-placeholder-32-bytes-lo

# AES 32字节测试密钥（SaTokenCryptoTest, StpLogicAdvancedTest）
TEST_AES_KEY_32=test-key-placeholder-32-bytes-lo

# HMAC 测试密钥（SaTokenCryptoTest）
TEST_HMAC_KEY=test-key-placeholder-32-bytes-lo

# 签名测试密钥（SaSignTest）
TEST_SIGN_KEY=test-key-placeholder-32-bytes-lo

# OAuth2 客户端测试密钥（SaOAuth2Test, SaOAuth2OpenIdTest）
TEST_OAUTH2_CLIENT_SECRET=test-key-placeholder-32-bytes-lo

# Token 加密测试密钥（TokenManagerTest）
TEST_ENCRYPT_KEY=test-key-placeholder-32-bytes-lo

# Token AES 测试密钥（TokenManagerTest）
TEST_AES_KEY_FOR_TOKEN=test-key-placeholder-32-bytes-lo

# SSO 客户端测试密钥（SaSsoTemplateTest）
TEST_SSO_CLIENT_SECRET=test-key-placeholder-32-bytes-lo

# Session 加密测试密钥（SaSessionEncryptTest）
TEST_ENCRYPT_KEY_SESSION=test-key-placeholder-32-bytes-lo

# SM4 Session 加密测试密钥（SaSessionEncryptTest）
TEST_SM4_ENCRYPT_KEY=test-key-placeholder-32-bytes-lo